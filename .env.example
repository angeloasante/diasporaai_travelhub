# TravelHub Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# AUTHENTICATION (MUST MATCH MAIN APP)
# ===========================================
# This MUST be the same AUTH_SECRET used in the main app (app.diasporaai.dev)
# Cross-subdomain authentication will fail if these don't match
AUTH_SECRET=

# Full URL where TravelHub is hosted
NEXTAUTH_URL=https://travelhub.diasporaai.dev

# ===========================================
# SUPABASE
# ===========================================
# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, keep secret!)
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# GOOGLE MAPS
# ===========================================
# Google Maps API key for itinerary maps
# Enable: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ===========================================
# AI / OPENAI
# ===========================================
# OpenAI API key for AI itinerary chat
OPENAI_API_KEY=

# ===========================================
# OPTIONAL: DEVELOPMENT
# ===========================================
# Set to 'development' for local testing
# NODE_ENV=development
