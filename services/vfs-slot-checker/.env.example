# VFS Slot Checker Environment Variables

# ===========================================
# CAPTCHA Solver Configuration (Required for automation)
# ===========================================
# Choose one of the supported services and add your API key:

# Option 1: 2Captcha (https://2captcha.com)
# - Sign up and get API key from dashboard
# - Supports Cloudflare Turnstile
# - Pricing: ~$2.99 per 1000 CAPTCHAs
CAPTCHA_API_KEY=your_2captcha_api_key_here
CAPTCHA_SERVICE=2captcha

# Option 2: CapSolver (https://capsolver.com)
# - Alternative service with similar pricing
# CAPTCHA_API_KEY=your_capsolver_api_key_here
# CAPTCHA_SERVICE=capsolver

# ===========================================
# Server Configuration
# ===========================================
# Port for the VFS API server (default: 8000)
VFS_API_PORT=8000

# URL of the TravelHub Next.js app (for CORS)
TRAVELHUB_URL=http://localhost:3000

# ===========================================
# Browser Configuration
# ===========================================
# Run browser in headless mode (true/false)
# Set to false for debugging or if headless is being blocked
HEADLESS=true

# Browser type: chromium, firefox, webkit
BROWSER_TYPE=chromium
